#: ../../source/getting_started/quick_start.rst:100
#: 7dacba9b801147d58a827d53957aada4
msgid "extends Node\n"
"\n"
"@onready var sfx_emitter = $FmodAudioSampleEmitter\n"
"\n"
"func play_jump_sound():\n"
"    var sample = FmodAudioSample.new()\n"
"    sample.file_path = \"res://sfx/jump.wav\"\n"
"\n"
"    sfx_emitter.sample = sample\n"
"    sfx_emitter.bus = \"SFX\"\n"
"    sfx_emitter.play()"
msgstr ""

#: ../../source/getting_started/quick_start.rst:115
#: c7d50831eb5f461e8a8195f0be993877
msgid "使用代码播放（不通过节点）"
msgstr ""

#: ../../source/getting_started/quick_start.rst:117
#: 3d32c30f16c34587a8d21cbfde150a3f
msgid "func play_sound_directly():\n"
"    # 获取 FMOD 系统\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # 从文件创建声音\n"
"    var sound = system.create_sound_from_file(\n"
"        \"res://sfx/explosion.wav\",\n"
"        FmodSystem.MODE_DEFAULT\n"
"    )\n"
"\n"
"    # 获取主通道组\n"
"    var master_group = system.get_master_channel_group()\n"
"\n"
"    # 播放声音\n"
"    var channel = system.play_sound(sound, master_group, false)"
msgstr ""

#: ../../source/getting_started/quick_start.rst:136
#: eb9d7394b7f14c72ba295f7871b78a9d
msgid "添加音效"
msgstr ""

#: ../../source/getting_started/quick_start.rst:138
#: a83649d6bc2440e188b2338166605fcf
msgid "func add_reverb_effect():\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # 创建混响 DSP\n"
"    var reverb = system.create_dsp_by_type(FmodDSP.DSP_TYPE_SFXREVERB)\n"
"\n"
"    # 设置混响参数\n"
"    reverb.set_parameter_float(0, 0.5)   # Decay time\n"
"    reverb.set_parameter_float(1, 0.3)   # Early delay\n"
"    reverb.set_parameter_float(2, 0.8)   # Late delay\n"
"    reverb.set_parameter_float(3, 0.5)   # HF decay ratio\n"
"\n"
"    # 添加到主通道组\n"
"    var master = system.get_master_channel_group()\n"
"    master.add_dsp(0, reverb)"
msgstr ""

#: ../../source/getting_started/quick_start.rst:157
#: bfdf15626231449d91c43c7fdfd867f0
msgid "控制播放"
msgstr ""

#: ../../source/getting_started/quick_start.rst:159
#: d3d14fbbefd54df887919fc4fcf29556
msgid "extends Node\n"
"\n"
"@onready var player = $FmodAudioStreamPlayer\n"
"\n"
"func _input(event):\n"
"    if event.is_action_pressed(\"ui_accept\"):\n"
"        if player.playing:\n"
"            player.stop()\n"
"        else:\n"
"            player.play()\n"
"\n"
"    if event.is_action_pressed(\"ui_up\"):\n"
"        # 增加音量\n"
"        player.volume_db += 3.0\n"
"\n"
"    if event.is_action_pressed(\"ui_down\"):\n"
"        # 降低音量\n"
"        player.volume_db -= 3.0"
msgstr ""

#: ../../source/getting_started/quick_start.rst:181
#: 57f9e641473d48f9bc79c67a05bec202
msgid "性能监控"
msgstr ""

#: ../../source/getting_started/quick_start.rst:183
#: 17a198b587054f28ba17fbc4966fd31b
msgid "extends Node\n"
"\n"
"func _process(delta):\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # 获取 CPU 使用率\n"
"    var cpu_usage = system.get_cpu_usage()\n"
"    print(\"DSP CPU: %.2f%%\" % cpu_usage[\"dsp\"])\n"
"\n"
"    # 获取正在播放的通道数\n"
"    var channels = system.get_channels_playing()\n"
"    print(\"Active channels: %d\" % channels[\"real\"])"
msgstr ""

