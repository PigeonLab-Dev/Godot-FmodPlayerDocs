msgid "基本流式播放"
msgstr ""

#: ../../source/getting_started/quick_start.rst:81
#: a79a1782271d45dbabf19b8739c0f51d
msgid "extends Node\n"
"\n"
"@onready var player = $FmodAudioStreamPlayer\n"
"\n"
"func _ready():\n"
"    # 创建流式音频资源\n"
"    var stream = FmodAudioStream.new()\n"
"    stream.file_path = \"res://music/background.mp3\"\n"
"\n"
"    # 设置播放器\n"
"    player.stream = stream\n"
"    player.volume_db = -6.0  # 稍微降低音量\n"
"    player.play()"
msgstr ""

#: ../../source/getting_started/quick_start.rst:98
