#: ../../source/api_reference/core.rst:224
#: e10f5379c93e41a09a446a1d5b4d21d5
msgid "通过 ``set_3d_rolloff_callback`` 可以设置自定义的 3D 声音距离衰减函数，替代 FMOD 内置的衰减算法。"
msgstr ""

#: ../../source/api_reference/core.rst:226
#: 4fa2ae40a44d4b139a293c6707803d3d
msgid "**回调函数签名：**"
msgstr ""

#: ../../source/api_reference/core.rst:228
#: 3af19219b1df4c84971f95104a42faa6
msgid "func custom_rolloff_callback(distance: float) -> float:\n"
"    # distance: 听众与声源的距离\n"
"    # 返回值: 音量衰减系数 (0.0 - 1.0)\n"
"    return 1.0 / (1.0 + distance * 0.1)"
msgstr ""

#: ../../source/api_reference/core.rst:235
#: 9434f90fa5424ebbb94abbb4b4d113e8
msgid "**示例：**"
msgstr ""

#: ../../source/api_reference/core.rst:237
#: 3a9f535982634183a7bbda6ce5bed641
msgid "var system = FmodServer.main_system\n"
"\n"
"# 创建声音\n"
"var sound = system.create_sound_from_file(\n"
"    \"res://music.mp3\",\n"
"    FmodSystem.MODE_LOOP_NORMAL | FmodSystem.MODE_CREATESTREAM\n"
")\n"
"\n"
"# 播放\n"
"var channel = system.play_sound(sound, null, false)\n"
"\n"
"# 获取性能信息\n"
"var cpu = system.get_cpu_usage()\n"
"print(\"DSP: %.2f%%\" % cpu[\"dsp\"])"
msgstr ""

