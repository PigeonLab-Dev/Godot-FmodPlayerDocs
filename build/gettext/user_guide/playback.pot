#: 2c6c388679614ee988f520b3573c9181
msgid "循环控制"
msgstr ""

#: ../../source/user_guide/playback.rst:245
#: 8ae9a01a33d7423a9bb9660a7ae9b701
msgid "func setup_looping(channel: FmodChannel):\n"
"    # 设置循环次数（-1 = 无限循环）\n"
"    channel.set_loop_count(-1)\n"
"\n"
"    # 设置循环次数（3次）\n"
"    channel.set_loop_count(3)\n"
"\n"
"    # 关闭循环\n"
"    channel.set_loop_count(0)"
