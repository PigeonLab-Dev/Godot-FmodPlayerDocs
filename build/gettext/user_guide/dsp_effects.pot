#: ../../source/user_guide/dsp_effects.rst:76
#: fc24c06dab2341d8b19c56087471401d
msgid "func create_dsp():\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # 通过类型创建 DSP\n"
"    var reverb = system.create_dsp_by_type(FmodDSP.DSP_TYPE_SFXREVERB)\n"
"\n"
"    # 或通过索引创建\n"
"    var delay = system.create_dsp_by_type(FmodDSP.DSP_TYPE_DELAY)"
msgstr ""

#: ../../source/user_guide/dsp_effects.rst:88
#: 76d8497fdf144a54b15c64a8f90d4674
msgid "添加到通道或总线"
msgstr ""

#: ../../source/user_guide/dsp_effects.rst:90
#: f588aa38423f41ce88fa4e3d98bd6ca3
msgid "func add_effects():\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # 创建混响\n"
"    var reverb = system.create_dsp_by_type(FmodDSP.DSP_TYPE_SFXREVERB)\n"
"\n"
"    # 添加到主总线\n"
"    var master = system.get_master_channel_group()\n"
"    master.add_dsp(0, reverb)  # 索引 0 表示信号链的开头\n"
"\n"
"    # 或者添加到特定通道\n"
"    var channel = play_some_sound()\n"
"    channel.add_dsp(0, reverb)"
msgstr ""

#: ../../source/user_guide/dsp_effects.rst:107
#: b6a1613687174a77b07e422eb69787eb
msgid "控制 DSP 参数"
msgstr ""

#: ../../source/user_guide/dsp_effects.rst:109
#: 7d1e16b8068247ff88f44459c4e94a96
msgid "func control_dsp(dsp: FmodDSP):\n"
"    # 启用/禁用\n"
"    dsp.set_active(true)\n"
"\n"
"    # 旁通（让信号通过但不处理）\n"
"    dsp.set_bypass(false)\n"
"\n"
"    # 设置参数（参数索引和值取决于 DSP 类型）\n"
"    dsp.set_parameter_float(0, 0.5)   # 浮点参数\n"
"    dsp.set_parameter_int(1, 44100)   # 整数参数\n"
"    dsp.set_parameter_bool(2, true)   # 布尔参数\n"
"\n"
"    # 获取参数\n"
"    var value = dsp.get_parameter_float(0)\n"
"\n"
"    # 获取参数信息\n"
"    var info = dsp.get_parameter_info(0)\n"
"    print(\"Parameter name: %s\" % info.name)\n"
"    print(\"Min: %f, Max: %f\" % [info.min, info.max])"
msgstr ""

#: ../../source/user_guide/dsp_effects.rst:132
#: 744a1fdcbbc3422bb8d6b502af587d6b
msgid "从通道/总线移除 DSP"
msgstr ""

#: ../../source/user_guide/dsp_effects.rst:134
#: cb054d16fabf4ce797d140419ea87c75
msgid "func remove_dsp():\n"
"    var master = FmodServer.main_system.get_master_channel_group()\n"
"    var dsp = master.get_dsp(0)  # 获取第一个 DSP\n"
"\n"
"    if dsp:\n"
"        master.remove_dsp(dsp)\n"
"        dsp.release()  # 释放 DSP 资源"
msgstr ""

