#: ../../source/user_guide/dsp_effects.rst:365
#: ac6bf57b7e8f45e697b2ded211b76f7a
msgid "class_name ReverbPreset\n"
"extends RefCounted\n"
"\n"
"const SMALL_ROOM = {\n"
"    \"decay\": 800.0,\n"
"    \"early_delay\": 7.0,\n"
"    \"late_delay\": 11.0,\n"
"    \"hf_decay\": 83.0,\n"
"    \"diffusion\": 100.0,\n"
"    \"density\": 100.0,\n"
"    \"wet_level\": -6.0\n"
"}\n"
"\n"
"const LARGE_HALL = {\n"
"    \"decay\": 4000.0,\n"
"    \"early_delay\": 20.0,\n"
"    \"late_delay\": 30.0,\n"
"    \"hf_decay\": 59.0,\n"
"    \"diffusion\": 100.0,\n"
"    \"density\": 100.0,\n"
"    \"wet_level\": -3.0\n"
"}\n"
"\n"
"static func apply(dsp: FmodDSP, preset: Dictionary):\n"
"    dsp.set_parameter_float(0, preset[\"decay\"])\n"
"    dsp.set_parameter_float(1, preset[\"early_delay\"])\n"
"    dsp.set_parameter_float(2, preset[\"late_delay\"])\n"
"    dsp.set_parameter_float(3, preset[\"hf_decay\"])\n"
"    dsp.set_parameter_float(4, preset[\"diffusion\"])\n"
"    dsp.set_parameter_float(5, preset[\"density\"])\n"
"    dsp.set_parameter_float(10, preset[\"wet_level\"])"
msgstr ""

