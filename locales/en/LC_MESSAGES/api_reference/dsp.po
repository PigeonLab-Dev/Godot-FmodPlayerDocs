#: ../../source/api_reference/dsp.rst:450 ce467c2085d34fde9d31608fb7d36bf3
#, python-brace-format
msgid ""
"func create_custom_dsp():\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # 创建自定义 DSP\n"
"    var dsp = system.create_dsp(\"MyCustomDSP\")\n"
"\n"
"    # 设置创建回调\n"
"    dsp.set_create_callback(func() -> int:\n"
"        print(\"DSP 已创建\")\n"
"        return 0  # FMOD_OK\n"
"    )\n"
"\n"
"    # 设置处理回调\n"
"    dsp.set_process_callback(func(length: int, in_buffers: Dictionary, "
"inputs_idle: bool, op: int) -> Dictionary:\n"
"        if op == 0:  # FMOD_DSP_PROCESS_QUERY\n"
"            # 返回支持的输出格式\n"
"            return {\n"
"                \"outchannels\": [2],  # 立体声输出\n"
"                \"result\": 0\n"
"            }\n"
"\n"
"        # op == 1: FMOD_DSP_PROCESS_PERFORM\n"
"        var out_buffers = {}\n"
"\n"
"        for i in in_buffers.keys():\n"
"            var in_data: PackedFloat32Array = in_buffers[i]\n"
"            var out_data = PackedFloat32Array()\n"
"            out_data.resize(in_data.size())\n"
"\n"
"            # 简单的增益处理\n"
"            for j in range(in_data.size()):\n"
"                out_data[j] = in_data[j] * 0.7  # 降低音量\n"
"\n"
"            out_buffers[i] = out_data\n"
"\n"
"        return {\n"
"            \"outbuffers\": out_buffers,\n"
"            \"outchannels\": [2],\n"
"            \"result\": 0  # FMOD_OK\n"
"        }\n"
"    )\n"
"\n"
"    # 设置释放回调\n"
"    dsp.set_release_callback(func() -> int:\n"
"        print(\"DSP 已释放\")\n"
"        return 0\n"
"    )\n"
"\n"
"    # 添加到主总线\n"
"    var master = system.get_master_channel_group()\n"
"    master.add_dsp(0, dsp)"
msgstr ""
"func create_custom_dsp():\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # Create custom DSP\n"
"    var dsp = system.create_dsp(\"MyCustomDSP\")\n"
"\n"
"    # Set create callback\n"
"    dsp.set_create_callback(func() -> int:\n"
"        print(\"DSP created\")\n"
"        return 0  # FMOD_OK\n"
"    )\n"
"\n"
"    # Set process callback\n"
"    dsp.set_process_callback(func(length: int, in_buffers: Dictionary, "
"inputs_idle: bool, op: int) -> Dictionary:\n"
"        if op == 0:  # FMOD_DSP_PROCESS_QUERY\n"
"            # Return supported output format\n"
"            return {\n"
"                \"outchannels\": [2],  # Stereo output\n"
"                \"result\": 0\n"
"            }\n"
"\n"
"        # op == 1: FMOD_DSP_PROCESS_PERFORM\n"
"        var out_buffers = {}\n"
"\n"
"        for i in in_buffers.keys():\n"
"            var in_data: PackedFloat32Array = in_buffers[i]\n"
"            var out_data = PackedFloat32Array()\n"
"            out_data.resize(in_data.size())\n"
"\n"
"            # Simple gain processing\n"
"            for j in range(in_data.size()):\n"
"                out_data[j] = in_data[j] * 0.7  # Reduce volume\n"
"\n"
"            out_buffers[i] = out_data\n"
"\n"
"        return {\n"
"            \"outbuffers\": out_buffers,\n"
"            \"outchannels\": [2],\n"
"            \"result\": 0  # FMOD_OK\n"
"        }\n"
"    )\n"
"\n"
"    # Set release callback\n"
"    dsp.set_release_callback(func() -> int:\n"
"        print(\"DSP released\")\n"
"        return 0\n"
"    )\n"
"\n"
"    # Add to master bus\n"
"    var master = system.get_master_channel_group()\n"
"    master.add_dsp(0, dsp)"

#: ../../source/api_reference/dsp.rst:505 0d3dcdff8a2147c3a195fdae91e09dbb
msgid "使用读取回调的简单效果器"
msgstr "Simple Effect Using Read Callback"

#: ../../source/api_reference/dsp.rst:507 5d6e80513e79488d990016badd588618
#, python-brace-format
msgid ""
"func create_simple_gain_dsp():\n"
"    var system = FmodServer.main_system\n"
"    var dsp = system.create_dsp(\"GainDSP\")\n"
"\n"
"    var gain = 0.5\n"
"\n"
"    # 设置读取回调（逐采样处理）\n"
"    dsp.set_read_callback(func(in_array: PackedFloat32Array, length: int,"
" in_channels: int) -> Dictionary:\n"
"        var out_array = PackedFloat32Array()\n"
"        out_array.resize(length * in_channels)\n"
"\n"
"        for i in range(length * in_channels):\n"
"            out_array[i] = in_array[i] * gain\n"
"\n"
"        return {\n"
"            \"output\": out_array,\n"
"            \"outchannels\": in_channels,\n"
"            \"result\": 0\n"
"        }\n"
"    )\n"
"\n"
"    # 设置参数回调以动态调整增益\n"
"    dsp.set_setparam_float_callback(func(index: int, value: float) -> "
"int:\n"
"        if index == 0:\n"
"            gain = value\n"
"        return 0\n"
"    )\n"
"\n"
"    dsp.set_getparam_float_callback(func(index: int) -> Dictionary:\n"
"        if index == 0:\n"
"            return {\"value\": gain, \"valuestr\": str(gain), \"result\":"
" 0}\n"
"        return {\"value\": 0.0, \"valuestr\": \"0\", \"result\": 0}\n"
"    )\n"
"\n"
"    return dsp"
msgstr ""
"func create_simple_gain_dsp():\n"
"    var system = FmodServer.main_system\n"
"    var dsp = system.create_dsp(\"GainDSP\")\n"
"\n"
"    var gain = 0.5\n"
"\n"
"    # Set read callback (per-sample processing)\n"
"    dsp.set_read_callback(func(in_array: PackedFloat32Array, length: int,"
" in_channels: int) -> Dictionary:\n"
"        var out_array = PackedFloat32Array()\n"
"        out_array.resize(length * in_channels)\n"
"\n"
"        for i in range(length * in_channels):\n"
"            out_array[i] = in_array[i] * gain\n"
"\n"
"        return {\n"
"            \"output\": out_array,\n"
"            \"outchannels\": in_channels,\n"
"            \"result\": 0\n"
"        }\n"
"    )\n"
"\n"
"    # Set parameter callback to dynamically adjust gain\n"
"    dsp.set_setparam_float_callback(func(index: int, value: float) -> "
"int:\n"
"        if index == 0:\n"
"            gain = value\n"
"        return 0\n"
"    )\n"
"\n"
"    dsp.set_getparam_float_callback(func(index: int) -> Dictionary:\n"
"        if index == 0:\n"
"            return {\"value\": gain, \"valuestr\": str(gain), \"result\":"
" 0}\n"
"        return {\"value\": 0.0, \"valuestr\": \"0\", \"result\": 0}\n"
"    )\n"
"\n"
"    return dsp"

