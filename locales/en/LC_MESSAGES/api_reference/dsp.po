msgstr ""
"func create_callback() -> int:\n"
"    # Return FMOD_RESULT enum value (FMOD_OK = 0)\n"
"    return 0"

#: ../../source/api_reference/dsp.rst:351 3f32e375aab042e6a6c18e18f922dee8
#, python-brace-format
msgid ""
"func process_callback(length: int, in_buffers: Dictionary, inputs_idle: "
"bool, op: int) -> Dictionary:\n"
"    # length: 采样数\n"
"    # in_buffers: 输入缓冲区字典 {索引: PackedFloat32Array}\n"
"    # inputs_idle: 输入是否空闲\n"
"    # op: 处理操作类型 (0=查询, 1=执行)\n"
"\n"
"    # 返回字典:\n"
"    return {\n"
"        \"outbuffers\": {0: output_array},  # 输出缓冲区\n"
"        \"outchannels\": [channel_count],   # 输出通道数\n"
"        \"result\": 0  # FMOD_RESULT\n"
"    }"
msgstr ""
"func process_callback(length: int, in_buffers: Dictionary, inputs_idle: "
"bool, op: int) -> Dictionary:\n"
"    # length: number of samples\n"
"    # in_buffers: input buffer dictionary {index: PackedFloat32Array}\n"
"    # inputs_idle: whether inputs are idle\n"
"    # op: processing operation type (0=query, 1=perform)\n"
"\n"
"    # Return dictionary:\n"
"    return {\n"
"        \"outbuffers\": {0: output_array},  # Output buffer\n"
"        \"outchannels\": [channel_count],   # Output channel count\n"
"        \"result\": 0  # FMOD_RESULT\n"
"    }"

#: ../../source/api_reference/dsp.rst:366 97381d2d360e464a80a07f84753e0812
msgid "**读取回调：**"
msgstr "**Read Callback:**"

#: ../../source/api_reference/dsp.rst:368 a4820e10ae844707aaf29ea3c244cec2
#, python-brace-format
msgid ""
"func read_callback(in_array: PackedFloat32Array, length: int, "
"in_channels: int) -> Dictionary:\n"
"    # in_array: 输入音频数据\n"
"    # length: 采样数\n"
"    # in_channels: 输入通道数\n"
"\n"
"    # 处理音频...\n"
"    var out_array = PackedFloat32Array()\n"
"    out_array.resize(length * in_channels)\n"
"\n"
"    for i in range(length * in_channels):\n"
"        out_array[i] = in_array[i] * 0.5  # 衰减\n"
"\n"
"    return {\n"
"        \"output\": out_array,\n"
"        \"outchannels\": in_channels,\n"
"        \"result\": 0  # FMOD_RESULT\n"
"    }"
msgstr ""
"func read_callback(in_array: PackedFloat32Array, length: int, "
"in_channels: int) -> Dictionary:\n"
"    # in_array: input audio data\n"
"    # length: number of samples\n"
"    # in_channels: input channel count\n"
"\n"
"    # Process audio...\n"
"    var out_array = PackedFloat32Array()\n"
"    out_array.resize(length * in_channels)\n"
"\n"
"    for i in range(length * in_channels):\n"
"        out_array[i] = in_array[i] * 0.5  # Attenuate\n"
"\n"
"    return {\n"
"        \"output\": out_array,\n"
"        \"outchannels\": in_channels,\n"
"        \"result\": 0  # FMOD_RESULT\n"
"    }"

