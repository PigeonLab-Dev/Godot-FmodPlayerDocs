#: ../../source/api_reference/audio.rst:104 ea5708952e924251b959f1ff111b786a
msgid "**从文件加载（流式模式 - 适合背景音乐）：**"
msgstr "**Load from file (streaming mode - suitable for background music):**"

#: ../../source/api_reference/audio.rst:106 2ac90a2d6f414f31b7afc860074c491e
msgid ""
"# 流式加载（默认）\n"
"var stream = "
"FmodAudioStream.load_from_file(\"res://music/background.mp3\")\n"
"stream.mode_flags = FmodAudioStream.MODE_STREAM | "
"FmodAudioStream.MODE_LOOP\n"
"\n"
"var player = $FmodAudioStreamPlayer\n"
"player.stream = stream\n"
"player.play()"
msgstr ""
"# Streaming load (default)\n"
"var stream = "
"FmodAudioStream.load_from_file(\"res://music/background.mp3\")\n"
"stream.mode_flags = FmodAudioStream.MODE_STREAM | "
"FmodAudioStream.MODE_LOOP\n"
"\n"
"var player = $FmodAudioStreamPlayer\n"
"player.stream = stream\n"
"player.play()"

#: ../../source/api_reference/audio.rst:116 0ac09a0a3185487eb52714d0b869f707
msgid "**从文件加载（样本模式 - 适合音效）：**"
msgstr "**Load from file (sample mode - suitable for sound effects):**"

#: ../../source/api_reference/audio.rst:118 2f6cd2d70ba6482086a6d4a49928a553
msgid ""
"# 样本模式加载到内存\n"
"var sfx = FmodAudioStream.load_from_file(\"res://sfx/explosion.wav\",\n"
"    FmodAudioStream.MODE_SAMPLE)\n"
"\n"
"var emitter = $FmodAudioSampleEmitter\n"
"emitter.stream = sfx\n"
"emitter.emit()"
msgstr ""
"# Sample mode load into memory\n"
"var sfx = FmodAudioStream.load_from_file(\"res://sfx/explosion.wav\",\n"
"    FmodAudioStream.MODE_SAMPLE)\n"
"\n"
"var emitter = $FmodAudioSampleEmitter\n"
"emitter.stream = sfx\n"
"emitter.emit()"

#: ../../source/api_reference/audio.rst:128 7df81caf5a2b4b558964bf48ad3d8a42
msgid "**从内存加载：**"
msgstr "**Load from memory:**"

#: ../../source/api_reference/audio.rst:130 3f9aa53f185f45498952869bb34c859d
msgid ""
"var stream = FmodAudioStream.new()\n"
