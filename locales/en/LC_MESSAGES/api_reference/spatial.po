#: ../../source/api_reference/spatial.rst:171 68b3eff2e3a64a9ebf7c0c75e01cd98a
msgid ""
"extends Node3D\n"
"\n"
"var wall_geometry: FmodGeometry\n"
"\n"
"func _ready():\n"
"    var system = FmodServer.main_system\n"
"\n"
"    # Create geometry (max 10 polygons, 100 vertices)\n"
"    wall_geometry = system.create_geometry(10, 100)\n"
"\n"
"    # Define wall rectangle (4 vertices)\n"
"    var vertices = [\n"
"        Vector3(-5, 0, 0),\n"
"        Vector3(5, 0, 0),\n"
"        Vector3(5, 3, 0),\n"
"        Vector3(-5, 3, 0)\n"
"    ]\n"
"\n"
"    # Add double-sided occlusion polygon\n"
"    wall_geometry.add_polygon(\n"
"        1.0,    # Full direct occlusion\n"
"        0.8,    # Strong reverb occlusion\n"
"        true,   # Double-sided occlusion\n"
"        4,      # 4 vertices\n"
"        vertices\n"
"    )\n"
"\n"
"    # Set position\n"
"    wall_geometry.position = Vector3(0, 0, 10)\n"
"\n"
"func _exit_tree():\n"
"    if wall_geometry:\n"
"        wall_geometry.release()"
msgstr ""

