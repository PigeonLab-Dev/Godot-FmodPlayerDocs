msgstr "Audio with Emission Angle"

#: ../../source/api_reference/nodes.rst:440 c37ff8f32128406ba8cb92595e859000
msgid ""
"extends Node3D\n"
"\n"
"@onready var speaker = $FmodAudioStreamPlayer3D\n"
"\n"
"func _ready():\n"
"    var stream = FmodAudioStream.load_from_file(\n"
"        \"res://audio/announcement.wav\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    )\n"
"\n"
"    speaker.stream = stream\n"
"\n"
"    # 启用定向发射（类似喇叭）\n"
"    speaker.emission_angle_enabled = true\n"
"    speaker.emission_angle = 30.0  # 30度内为清晰区域\n"
"    speaker.emission_angle_filter_attenuation_db = -20.0\n"
"\n"
"    # 让发射方向跟随节点旋转\n"
"    speaker.rotation.y = PI / 4  # 指向特定方向"
msgstr ""
"extends Node3D\n"
"\n"
"@onready var speaker = $FmodAudioStreamPlayer3D\n"
"\n"
"func _ready():\n"
"    var stream = FmodAudioStream.load_from_file(\n"
"        \"res://audio/announcement.wav\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    )\n"
"\n"
"    speaker.stream = stream\n"
"\n"
"    # Enable directional emission (like a speaker)\n"
"    speaker.emission_angle_enabled = true\n"
"    speaker.emission_angle = 30.0  # Clear zone within 30 degrees\n"
"    speaker.emission_angle_filter_attenuation_db = -20.0\n"
"\n"
"    # Make emission direction follow node rotation\n"
"    speaker.rotation.y = PI / 4  # Point in specific direction"

#: ../../source/api_reference/nodes.rst:463 ff4ce03bf2e741fdba09cd0ca9e2e4da
msgid "动态控制 3D 音频"
msgstr "Dynamic 3D Audio Control"

#: ../../source/api_reference/nodes.rst:465 794dd984616b4b5581bca4133763d9bf
msgid ""
"extends CharacterBody3D\n"
"\n"
"@onready var engine_sound = $FmodAudioStreamPlayer3D\n"
"\n"
"func _ready():\n"
"    var stream = FmodAudioStream.load_from_file(\n"
"        \"res://audio/engine.wav\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    )\n"
"\n"
"    engine_sound.stream = stream\n"
"    engine_sound.doppler_tracking = "
"FmodAudioStreamPlayer3D.DOPPLER_TRACKING_PHYSICS_STEP\n"
"    engine_sound.attenuation_model = "
"FmodAudioStreamPlayer3D.ATTENUATION_INVERSE_SQUARE_DISTANCE\n"
"    engine_sound.max_distance = 50.0\n"
"    engine_sound.play()\n"
"\n"
"func _physics_process(delta):\n"
"    # 根据速度调整音调\n"
"    var speed = velocity.length()\n"
"    engine_sound.pitch = 1.0 + (speed / 100.0)"
msgstr ""
"extends CharacterBody3D\n"
"\n"
"@onready var engine_sound = $FmodAudioStreamPlayer3D\n"
"\n"
"func _ready():\n"
"    var stream = FmodAudioStream.load_from_file(\n"
"        \"res://audio/engine.wav\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    )\n"
"\n"
"    engine_sound.stream = stream\n"
"    engine_sound.doppler_tracking = "
"FmodAudioStreamPlayer3D.DOPPLER_TRACKING_PHYSICS_STEP\n"
"    engine_sound.attenuation_model = "
"FmodAudioStreamPlayer3D.ATTENUATION_INVERSE_SQUARE_DISTANCE\n"
"    engine_sound.max_distance = 50.0\n"
"    engine_sound.play()\n"
"\n"
"func _physics_process(delta):\n"
"    # Adjust pitch based on speed\n"
"    var speed = velocity.length()\n"
"    engine_sound.pitch = 1.0 + (speed / 100.0)"

