#: ../../source/api_reference/nodes.rst:182 d9b3630f1ee74c7591d7193d79f83a5a
msgid ""
"extends Node\n"
"\n"
"@onready var emitter = $FmodAudioSampleEmitter\n"
"var shoot_stream: FmodAudioStream\n"
"\n"
"func _ready():\n"
"    # 预加载音效（样本模式）\n"
"    shoot_stream = "
"FmodAudioStream.load_from_file(\"res://sfx/shoot.wav\",\n"
"        FmodAudioStream.MODE_SAMPLE)\n"
"\n"
"    emitter.stream = shoot_stream\n"
"    emitter.bus = \"SFX\"\n"
"\n"
"func _input(event):\n"
"    if event.is_action_pressed(\"shoot\"):\n"
"        play_shoot_sound()\n"
"\n"
"func play_shoot_sound():\n"
"    emitter.emit()\n"
"\n"
"# 自动发射示例\n"
"func setup_auto_emit():\n"
"    var stream = "
"FmodAudioStream.load_from_file(\"res://sfx/heartbeat.wav\",\n"
"        FmodAudioStream.MODE_SAMPLE)\n"
"\n"
"    emitter.stream = stream\n"
"    emitter.auto_emit = true  # 设置流时自动播放"
msgstr ""

