msgid "说明"
msgstr "Description"

#: ../../source/getting_started/quick_start.rst:121
#: 21994ae405a040d79625c3fcf3d98b2a
msgid "``stream``"
msgstr "``stream``"

#: ../../source/getting_started/quick_start.rst:122
#: 7d4b24cb27814b6a8b2abc79dbadc8a5
msgid "要播放的 ``FmodAudioStream``。"
msgstr "The ``FmodAudioStream`` to play."

#: ../../source/getting_started/quick_start.rst:123
#: 5cbaa478d59d4707bf1db69cb6429f07
msgid "``playing``"
msgstr "``playing``"

#: ../../source/getting_started/quick_start.rst:124
#: 79419627fe8f4826a032372b0c596945
msgid "开始或停止播放。"
msgstr "Starts or stops playback."

#: ../../source/getting_started/quick_start.rst:125
#: bcfa9a48590a4710a77ebe52ae2bf0a6
