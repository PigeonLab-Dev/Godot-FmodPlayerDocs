#: ../../source/export.rst:2
#: fef501ec99a242e585675f74c7a6d2ce
msgid "导出说明"
msgstr "Export Guide"

#: ../../source/export.rst:4
#: aa41b099678e4ff38d4387fa4e0271c5
msgid "本文说明如何在导出 Godot 项目时打包 Godot-FmodPlayer 和 FMOD 运行库。 如果你还没有完成插件安装，请先阅读 :doc:`getting_started/installation`。"
msgstr ""
"This page explains how to package Godot-FmodPlayer and the FMOD runtime libraries when exporting a Godot project. If you have not installed the plugin yet, read :doc:`getting_started/installation` first."

#: ../../source/export.rst:8
#: 5f9724dded4146e1adc0c322eb8ab673
msgid "导出前检查"
msgstr "Before Exporting"

#: ../../source/export.rst:11
#: 06d12e0207eb45c6aa0259ccf83d3b52
msgid "确认插件文件"
msgstr "Check Plugin Files"

#: ../../source/export.rst:13
#: 4e5d0927ec2d4d6eb1952664e71f01f3
msgid "导出前，项目中应包含 ``addons/fmod_player`` 插件目录。Windows 项目通常至少需要："
msgstr ""
"Before exporting, the project should contain the ``addons/fmod_player`` plugin directory. A Windows project usually needs at least:"

#: ../../source/export.rst:15
#: 37e251f1f7fa4d70a2fb0072a0aa897d
msgid ""
"res://\n"
"└── addons/\n"
"    └── fmod_player/\n"
"        ├── plugin.cfg\n"
"        ├── fmod_check.gd\n"
"        ├── fmod_player_main.gd\n"
"        └── bin/\n"
"            ├── fmod_player.gdextension\n"
"            ├── fmod.dll\n"
"            ├── fmod_player.windows.template_debug.x86_64.dll\n"
"            ├── fmod_player.windows.template_release.x86_64.dll\n"
"            └── icons/"
msgstr ""
"res://\n"
"└── addons/\n"
"    └── fmod_player/\n"
"        ├── plugin.cfg\n"
"        ├── fmod_check.gd\n"
"        ├── fmod_player_main.gd\n"
"        └── bin/\n"
"            ├── fmod_player.gdextension\n"
"            ├── fmod.dll\n"
"            ├── fmod_player.windows.template_debug.x86_64.dll\n"
"            ├── fmod_player.windows.template_release.x86_64.dll\n"
"            └── icons/"

#: ../../source/export.rst:32
#: 4ec329de8a38497fbed93bf152894e71
msgid "FMOD 运行库不会随插件一起分发。你需要自行从 `FMOD 下载页面 <https://www.fmod.com/download>`_ 下载 FMOD Engine， 并根据目标平台复制对应的运行库。"
msgstr ""
"The FMOD runtime libraries are not distributed with the plugin. Download FMOD Engine yourself from the `FMOD download page <https://www.fmod.com/download>`_ and copy the matching runtime libraries for your target platform."

#: ../../source/export.rst:37
#: 6899187601c5420ea7b42e863f0d632e
msgid "确认 GDExtension 配置"
msgstr "Check the GDExtension Configuration"

#: ../../source/export.rst:39
#: 6e01a81dad14470497cc45da68beaf14
msgid "当前插件默认支持 Windows x86_64 和 Android arm64。``addons/fmod_player/bin/fmod_player.gdextension`` 中应包含类似配置："
msgstr ""
"The plugin currently supports Windows x86_64 and Android arm64 by default. ``addons/fmod_player/bin/fmod_player.gdextension`` should contain configuration similar to:"

#: ../../source/export.rst:42
#: 9ff539f240504a11a62653357674c072
msgid ""
"[configuration]\n"
"entry_symbol = \"fmod_player_init\"\n"
"compatibility_minimum = \"4.1\"\n"
"reloadable = true\n"
"\n"
"[libraries]\n"
"windows.debug.x86_64 = \"fmod_player.windows.template_debug.x86_64.dll\"\n"
"windows.release.x86_64 = \"fmod_player.windows.template_release.x86_64.dll\"\n"
"android.debug.arm64 = \"libfmod_player.android.template_debug.arm64.so\"\n"
"android.release.arm64 = \"libfmod_player.android.template_release.arm64.so\"\n"
"\n"
"[dependencies]\n"
"windows.debug.x86_64 = { \"fmod.dll\" : \"\" }\n"
"windows.release.x86_64 = { \"fmod.dll\" : \"\" }"
msgstr ""
"[configuration]\n"
"entry_symbol = \"fmod_player_init\"\n"
"compatibility_minimum = \"4.1\"\n"
"reloadable = true\n"
"\n"
"[libraries]\n"
"windows.debug.x86_64 = \"fmod_player.windows.template_debug.x86_64.dll\"\n"
"windows.release.x86_64 = \"fmod_player.windows.template_release.x86_64.dll\"\n"
"android.debug.arm64 = \"libfmod_player.android.template_debug.arm64.so\"\n"
"android.release.arm64 = \"libfmod_player.android.template_release.arm64.so\"\n"
"\n"
"[dependencies]\n"
"windows.debug.x86_64 = { \"fmod.dll\" : \"\" }\n"
"windows.release.x86_64 = { \"fmod.dll\" : \"\" }"

