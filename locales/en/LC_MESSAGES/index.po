#: ../../source/index.rst:82 8e499d267cd94f9fba8bf7a45cae5169
msgid "基本流式播放::"
msgstr ""

#: ../../source/index.rst:84 3a86da53d62c4e3a8826eacec736d6b9
msgid ""
"extends Node\n"
"\n"
"@onready var player = $FmodAudioStreamPlayer\n"
"\n"
"func _ready():\n"
"    var stream = FmodAudioStream.new()\n"
"    stream.file_path = \"res://music/background.mp3\"\n"
"\n"
"    player.stream = stream\n"
"    player.volume_db = -6.0\n"
"    player.play()"
msgstr ""

#: ../../source/index.rst:96 29aed5cab54b4638a076c7edc272b766
msgid "采样播放（一次性音效）::"
msgstr ""

#: ../../source/index.rst:98 dcfcfbba7bbd42a486b5a98ec27230e9
msgid ""
"func play_explosion():\n"
"    var emitter = $FmodAudioSampleEmitter\n"
"    var sample = FmodAudioSample.new()\n"
"    sample.file_path = \"res://sfx/explosion.wav\"\n"
"\n"
"    emitter.sample = sample\n"
"    emitter.bus = \"SFX\"\n"
"    emitter.play()"
msgstr ""

#: ../../source/index.rst:107 990ab31183de4ae68b15ffd3060885c0
msgid "添加混响效果::"
msgstr ""

#: ../../source/index.rst:109 9b83d9fb52b04974bbeaa882dfc79582
msgid ""
"func add_reverb():\n"
"    var system = FmodServer.main_system\n"
"    var reverb = system.create_dsp_by_type(FmodDSP.DSP_TYPE_SFXREVERB)\n"
"\n"
"    reverb.set_parameter_float(0, 0.5)  # Decay time\n"
"    reverb.set_parameter_float(1, 0.3)  # Early delay\n"
"\n"
"    var master_bus = system.get_master_channel_group()\n"
"    master_bus.add_dsp(0, reverb)"
msgstr ""

