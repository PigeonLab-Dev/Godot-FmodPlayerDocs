#: ../../source/user_guide/dsp_effects.rst:64
#: 5e5d392bc8b24e63a145f45ea096cc13
msgid "给总线添加效果"
msgstr "Add an Effect to a Bus"

#: ../../source/user_guide/dsp_effects.rst:66
#: 87cabf9ffe884a68a7c77196b72cf63d
msgid "下面示例给 ``Music`` 总线加一个低通滤波器。它会让音乐听起来更闷，适合暂停菜单、角色潜水、隔墙听声等场景。"
msgstr ""
"The following example adds a low-pass filter to the ``Music`` bus. It makes the music sound muffled, which is useful for pause menus, underwater scenes, or hearing sound through walls."

#: ../../source/user_guide/dsp_effects.rst:68
#: 896ef3e9eb64485c86a0f7cbc9b3ea21
msgid ""
"func add_pause_filter():\n"
"    var layout := FmodServer.get_audio_bus_layout()\n"
"\n"
"    var filter := FmodAudioEffectFilter.new()\n"
"    filter.cutoff_hz = 1200.0\n"
"    filter.resonance = 0.2\n"
"\n"
"    layout.add_bus_effect(\"Music\", filter)"
msgstr ""
"func add_pause_filter():\n"
"    var layout := FmodServer.get_audio_bus_layout()\n"
"\n"
"    var filter := FmodAudioEffectFilter.new()\n"
"    filter.cutoff_hz = 1200.0\n"
"    filter.resonance = 0.2\n"
"\n"
"    layout.add_bus_effect(\"Music\", filter)"

#: ../../source/user_guide/dsp_effects.rst:79
#: a9471e7d949e49bb976b7f5554e89408
msgid "效果加到总线后，经过这条 :ref:`Bus<glossary-bus>` 的声音都会受影响。"
msgstr "After an effect is added to a bus, all sounds passing through that :ref:`Bus<glossary-bus>` are affected."

#: ../../source/user_guide/dsp_effects.rst:82
#: b7009ff036f54367adc964d6de5687b4
msgid "旁路效果"
msgstr "Bypass Effects"

#: ../../source/user_guide/dsp_effects.rst:84
#: fa3f1993782b492da98cb9faa5a86544
msgid "如果只是临时关闭效果，优先用旁路，而不是反复创建和删除。"
msgstr "If you only need to temporarily disable an effect, prefer bypassing it instead of repeatedly creating and deleting it."

#: ../../source/user_guide/dsp_effects.rst:86
#: 91dcc7a137804fc5b565567260328d88
msgid ""
"func set_music_effects_enabled(enabled: bool):\n"
"    var layout := FmodServer.get_audio_bus_layout()\n"
"    layout.set_bus_bypass(\"Music\", not enabled)"
msgstr ""
"func set_music_effects_enabled(enabled: bool):\n"
"    var layout := FmodServer.get_audio_bus_layout()\n"
"    layout.set_bus_bypass(\"Music\", not enabled)"

#: ../../source/user_guide/dsp_effects.rst:92
#: a0f47c551ea1405f9f0a3d36c736e5e8
msgid "旁路的意思是：信号仍然通过，但跳过这条总线上的效果处理。"
msgstr "Bypass means the signal still passes through, but the effects on that bus are skipped."

#: ../../source/user_guide/dsp_effects.rst:95
#: 66c970088c574d1295b4020e8c1ba066
msgid "常用效果示例"
msgstr "Common Effect Examples"

#: ../../source/user_guide/dsp_effects.rst:98
#: 46396afdda504f22a57b205040402fa5
msgid "暂停菜单：音乐变闷"
msgstr "Pause menu: muffle the music"

#: ../../source/user_guide/dsp_effects.rst:100
#: 8499d32852b14458b6889c5dd20eb10c
msgid ""
"var pause_filter := FmodAudioEffectFilter.new()\n"
"\n"
"func _ready():\n"
"    pause_filter.cutoff_hz = 1000.0\n"
"    pause_filter.resonance = 0.1\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Music\", pause_filter)\n"
"    FmodServer.get_audio_bus_layout().set_bus_bypass(\"Music\", true)\n"
"\n"
"func set_paused_audio(paused: bool):\n"
"    FmodServer.get_audio_bus_layout().set_bus_bypass(\"Music\", not paused)"
msgstr ""
"var pause_filter := FmodAudioEffectFilter.new()\n"
"\n"
"func _ready():\n"
"    pause_filter.cutoff_hz = 1000.0\n"
"    pause_filter.resonance = 0.1\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Music\", pause_filter)\n"
"    FmodServer.get_audio_bus_layout().set_bus_bypass(\"Music\", true)\n"
"\n"
"func set_paused_audio(paused: bool):\n"
"    FmodServer.get_audio_bus_layout().set_bus_bypass(\"Music\", not paused)"

#: ../../source/user_guide/dsp_effects.rst:114
#: 79ac375ae23945aea452a186ec529e51
msgid "房间混响：给环境声加空间感"
msgstr "Room reverb: add space to ambience"

#: ../../source/user_guide/dsp_effects.rst:116
#: ca2db947206941bd8d776fca791b7900
msgid ""
"func setup_room_reverb():\n"
"    var reverb := FmodAudioEffectReverb.new()\n"
"    reverb.room_size = 0.7\n"
"    reverb.damping = 0.45\n"
"    reverb.wet = 0.35\n"
"    reverb.dry = 1.0\n"
"\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Ambient\", reverb)"
msgstr ""
"func setup_room_reverb():\n"
"    var reverb := FmodAudioEffectReverb.new()\n"
"    reverb.room_size = 0.7\n"
"    reverb.damping = 0.45\n"
"    reverb.wet = 0.35\n"
"    reverb.dry = 1.0\n"
"\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Ambient\", reverb)"

#: ../../source/user_guide/dsp_effects.rst:128
#: a560d9a8464b4eb9ac1bcdc285251d68
msgid "均衡器：削弱刺耳频段"
msgstr "Equalizer: reduce harsh frequencies"

#: ../../source/user_guide/dsp_effects.rst:130
#: 9d0921fcbade41189f7e4521dfb01d50
msgid ""
"func soften_sfx():\n"
"    var eq := FmodAudioEffectEQ10.new()\n"
"\n"
"    # 降低较高频段，让音效不那么刺耳。\n"
"    eq.set_band_gain_db(7, -3.0)\n"
"    eq.set_band_gain_db(8, -4.0)\n"
"\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"SFX\", eq)"
msgstr ""
"func soften_sfx():\n"
"    var eq := FmodAudioEffectEQ10.new()\n"
"\n"
"    # Lower the higher bands so the effect is less harsh.\n"
"    eq.set_band_gain_db(7, -3.0)\n"
"    eq.set_band_gain_db(8, -4.0)\n"
"\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"SFX\", eq)"

#: ../../source/user_guide/dsp_effects.rst:142
#: 5525ce2df4f44ab2865bc0242411f279
msgid "延迟：给特殊音效加回声"
msgstr "Delay: add echo to a special voice effect"

#: ../../source/user_guide/dsp_effects.rst:144
#: 2ee7569a0f2a4f77be26ceed71941381
msgid ""
"func add_echo_to_voice_bus():\n"
"    var delay := FmodAudioEffectDelay.new()\n"
"    delay.tap1_delay_ms = 180.0\n"
"    delay.tap1_level_db = -8.0\n"
"    delay.tap2_active = false\n"
"    delay.feedback_active = true\n"
"    delay.feedback_delay_ms = 260.0\n"
"    delay.feedback_level_db = -12.0\n"
"\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Voice\", delay)"
msgstr ""
"func add_echo_to_voice_bus():\n"
"    var delay := FmodAudioEffectDelay.new()\n"
"    delay.tap1_delay_ms = 180.0\n"
"    delay.tap1_level_db = -8.0\n"
"    delay.tap2_active = false\n"
"    delay.feedback_active = true\n"
"    delay.feedback_delay_ms = 260.0\n"
"    delay.feedback_level_db = -12.0\n"
"\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Voice\", delay)"

#: ../../source/user_guide/dsp_effects.rst:158
#: 9ab284cff90244baaacdb040afe22575
msgid "频谱分析：读取音乐能量"
msgstr "Spectrum analysis: read music energy"

#: ../../source/user_guide/dsp_effects.rst:160
#: 96a6aa48e15c4d52a25db7dd4a27a583
msgid "``FmodAudioEffectSpectrumAnalyzer`` 不改变声音，它只是读取频谱数据。适合音乐可视化、根据低频驱动画面等。"
msgstr ""
"``FmodAudioEffectSpectrumAnalyzer`` does not change the sound. It only reads spectrum data, which is useful for music visualization or driving visuals from bass energy."

#: ../../source/user_guide/dsp_effects.rst:162
#: 20d6cb165e974e9db5eae34a989b44c0
msgid ""
"var analyzer := FmodAudioEffectSpectrumAnalyzer.new()\n"
"\n"
"func _ready():\n"
"    analyzer.fft_size = FmodAudioEffectSpectrumAnalyzer.FFT_SIZE_2048\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Music\", analyzer)\n"
"\n"
"func _process(_delta):\n"
"    analyzer.update_spectrum()\n"
"\n"
"    var bass := analyzer.get_magnitude_for_frequency_range(\n"
"        20.0,\n"
"        250.0,\n"
"        FmodAudioEffectSpectrumAnalyzer.MAGNITUDE_AVERAGE\n"
"    )\n"
"\n"
"    print(\"bass energy: \", bass.length())"
msgstr ""
"var analyzer := FmodAudioEffectSpectrumAnalyzer.new()\n"
"\n"
"func _ready():\n"
"    analyzer.fft_size = FmodAudioEffectSpectrumAnalyzer.FFT_SIZE_2048\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Music\", analyzer)\n"
"\n"
"func _process(_delta):\n"
"    analyzer.update_spectrum()\n"
"\n"
"    var bass := analyzer.get_magnitude_for_frequency_range(\n"
"        20.0,\n"
"        250.0,\n"
"        FmodAudioEffectSpectrumAnalyzer.MAGNITUDE_AVERAGE\n"
"    )\n"
"\n"
"    print(\"bass energy: \", bass.length())"

#: ../../source/user_guide/dsp_effects.rst:182
#: b4c90b0462b2418ba2710eefd173168e
msgid "录音：录下某条总线"
msgstr "Recording: record a bus"

#: ../../source/user_guide/dsp_effects.rst:184
#: 092d14abfe234ef6af74e9ba6976cc79
msgid "``FmodAudioEffectRecord`` 会让声音原样通过，同时在录制开启时缓存经过总线的音频。"
msgstr ""
"``FmodAudioEffectRecord`` lets the sound pass through unchanged while caching the audio that passes through the bus when recording is enabled."

#: ../../source/user_guide/dsp_effects.rst:186
#: c7b151a36fa449fba724db70e11a1bd4
msgid ""
"var recorder := FmodAudioEffectRecord.new()\n"
"\n"
"func _ready():\n"
"    recorder.format = FmodAudioEffectRecord.FORMAT_16_BITS\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Master\", recorder)\n"
"\n"
"func start_recording():\n"
"    recorder.recording_active = true\n"
"\n"
"func stop_recording() -> AudioStreamWAV:\n"
"    recorder.recording_active = false\n"
"    return recorder.get_recording()"
msgstr ""
"var recorder := FmodAudioEffectRecord.new()\n"
"\n"
"func _ready():\n"
"    recorder.format = FmodAudioEffectRecord.FORMAT_16_BITS\n"
"    FmodServer.get_audio_bus_layout().add_bus_effect(\"Master\", recorder)\n"
"\n"
"func start_recording():\n"
"    recorder.recording_active = true\n"
"\n"
"func stop_recording() -> AudioStreamWAV:\n"
"    recorder.recording_active = false\n"
"    return recorder.get_recording()"

#: ../../source/user_guide/dsp_effects.rst:202
#: 429d3d2ee4054165bcadd72352bfbc0b
msgid "效果顺序"
msgstr "Effect Order"

#: ../../source/user_guide/dsp_effects.rst:204
#: ae7ae9c2c4484756adeadb7a46109a94
msgid "多个 :ref:`DSP<glossary-dsp>` 会组成 :ref:`DSP 链<glossary-dsp-chain>`。声音会按顺序经过它们，所以顺序会影响听感。"
msgstr ""
"Multiple :ref:`DSP<glossary-dsp>` units form a :ref:`DSP Chain<glossary-dsp-chain>`. Sound passes through them in order, so the order affects how it sounds."

#: ../../source/user_guide/dsp_effects.rst:206
#: 845fcd279ed440efb6f5059aebad39a6
msgid "一个容易理解的默认顺序是："
msgstr "An easy default order to understand is:"

#: ../../source/user_guide/dsp_effects.rst:208
#: 0e367de634b74d0c92abf0e7016978c0
msgid "均衡器 / 滤波器 -> 压缩器 -> 失真 -> 延迟 / 混响 -> 分析器 / 录音"
msgstr "Equalizer / filter -> compressor -> distortion -> delay / reverb -> analyzer / recorder"

#: ../../source/user_guide/dsp_effects.rst:212
#: 5e0ec1c0de31476ebc5fb15f1e3aa56a
msgid "这不是硬规则。比如先失真再混响，和先混响再失真，听起来会很不一样。调效果时建议一次只改一个变量，边听边调。"
msgstr ""
"This is not a hard rule. Distortion before reverb and reverb before distortion can sound very different. When tuning effects, change one variable at a time and listen as you adjust."

#: ../../source/user_guide/dsp_effects.rst:215
#: a9d5004c72c943c3a4f006830cc55c7e
msgid "什么时候直接用 FmodDSP"
msgstr "When to Use FmodDSP Directly"

#: ../../source/user_guide/dsp_effects.rst:217
#: 531cb0c03bdf499682919967c9353f99
msgid "``FmodAudioEffect*`` 更适合用户指南里的常规用法；``FmodDSP`` 更接近底层 FMOD。"
msgstr "``FmodAudioEffect*`` is better for the common workflows in this guide; ``FmodDSP`` is closer to low-level FMOD."

#: ../../source/user_guide/dsp_effects.rst:219
#: fa03e2105de84b5ebbf1a1b8a5a41b8e
msgid "只有在这些情况才建议直接用 :ref:`FmodDSP<FmodDSP>`："
msgstr "Use :ref:`FmodDSP<FmodDSP>` directly only when:"

#: ../../source/user_guide/dsp_effects.rst:221
#: c01bfadd1e9a497ab25f5d23dfa06450
msgid "需要访问 FMOD 内置 DSP 的原始参数索引。"
msgstr "You need access to raw parameter indices of FMOD built-in DSPs."

#: ../../source/user_guide/dsp_effects.rst:222
#: 68334579149744bb8a777fee2069f976
msgid "需要手动插入某个 :ref:`Channel<glossary-channel>` 的 DSP 链。"
msgstr "You need to manually insert a DSP into a specific :ref:`Channel<glossary-channel>` DSP chain."

#: ../../source/user_guide/dsp_effects.rst:223
#: 453b204222a44adc99c8de0b04097e56
msgid "需要自定义 DSP 回调或做实验性处理。"
msgstr "You need custom DSP callbacks or experimental processing."

#: ../../source/user_guide/dsp_effects.rst:224
#: 4f1bddd085764e659f3c271eee8dda30
msgid "你已经知道对应 DSP 的参数含义和范围。"
msgstr "You already know the meaning and range of the corresponding DSP parameters."

#: ../../source/user_guide/dsp_effects.rst:226
#: 36b803f46ccb4f77809d3f9e75f03759
msgid "一个最小示例："
msgstr "A minimal example:"

#: ../../source/user_guide/dsp_effects.rst:228
#: db5b1376d4324ffdb4707dbce881da09
msgid ""
"func add_low_level_reverb():\n"
"    var system := FmodServer.main_system\n"
"    var reverb := system.create_dsp_by_type(FmodDSP.DSP_TYPE_SFXREVERB)\n"
"    var master := system.get_master_channel_group()\n"
"\n"
"    master.add_dsp(0, reverb)"
msgstr ""
"func add_low_level_reverb():\n"
"    var system := FmodServer.main_system\n"
"    var reverb := system.create_dsp_by_type(FmodDSP.DSP_TYPE_SFXREVERB)\n"
"    var master := system.get_master_channel_group()\n"
"\n"
"    master.add_dsp(0, reverb)"

#: ../../source/user_guide/dsp_effects.rst:237
#: 1d784797f4dd42288984402782e5b5fc
msgid "低层 DSP 参数通常是数字索引，不如 ``FmodAudioEffectReverb.room_size`` 这类属性直观。普通项目优先使用效果资源类。"
msgstr ""
"Low-level DSP parameters are usually numeric indices and are less intuitive than properties such as ``FmodAudioEffectReverb.room_size``. For regular projects, prefer effect resource classes."

#: ../../source/user_guide/dsp_effects.rst:240
#: ca33ea2576bc4bc0a888c6d2e84630a5
msgid "性能建议"
msgstr "Performance Tips"

#: ../../source/user_guide/dsp_effects.rst:242
#: 797c8baf0fb948ed838bbd2f245e2c63
msgid "每个启用的 :ref:`DSP<glossary-dsp>` 都会增加 CPU 开销。"
msgstr "Each enabled :ref:`DSP<glossary-dsp>` adds CPU cost."

#: ../../source/user_guide/dsp_effects.rst:243
#: 8b4e41fd09324294803e28232e35b8a1
msgid "多个声音共享同一种效果时，放到总线上通常更省。"
msgstr "When multiple sounds share the same effect, putting it on a bus is usually cheaper."

#: ../../source/user_guide/dsp_effects.rst:244
#: c4aee91a15e743f4a4cc9096b104b6a0
msgid "临时关闭效果时，用旁路比反复添加、移除更稳定。"
msgstr "When temporarily disabling an effect, bypassing is more stable than repeatedly adding and removing it."

#: ../../source/user_guide/dsp_effects.rst:245
#: 7c3a3354ebc44e4cb20fe51f6608cda2
msgid "频谱分析和音高变换这类 FFT 效果更容易吃 CPU。"
msgstr "FFT effects such as spectrum analysis and pitch shifting are more CPU-hungry."

#: ../../source/user_guide/dsp_effects.rst:246
#: d83fe1a5a1084b88856888df293ba87f
msgid "不要每帧大幅跳变参数；需要变化时用插值或 Tween。"
msgstr "Do not make large parameter jumps every frame; use interpolation or Tween when values need to change."

#: ../../source/user_guide/dsp_effects.rst:249
#: 1b6b5988a870482da2a17b9011d8645a
msgid "排查清单"
msgstr "Troubleshooting Checklist"

#: ../../source/user_guide/dsp_effects.rst:251
#: 9225639cead14e45a3bf922775292404
msgid "效果没有声音变化时，先检查："
msgstr "If an effect does not change the sound, check:"

#: ../../source/user_guide/dsp_effects.rst:253
#: a52603d494c44bc88780fd9b77254c9e
msgid "声音是否真的输出到这条 :ref:`Bus<glossary-bus>`。"
msgstr "Whether the sound is really routed to this :ref:`Bus<glossary-bus>`."

#: ../../source/user_guide/dsp_effects.rst:254
#: 7fa3900daf8541468196127291899425
msgid "总线是否被旁路。"
msgstr "Whether the bus is bypassed."

#: ../../source/user_guide/dsp_effects.rst:255
#: c39b1e31bfe942b58303c00fe54453df
msgid "效果参数是否太轻，听不出来。"
msgstr "Whether the effect parameters are too subtle to hear."

#: ../../source/user_guide/dsp_effects.rst:256
#: 4866a1370a0345b596cb4719c6b5b40b
msgid "效果是否加到了错误的总线。"
msgstr "Whether the effect was added to the wrong bus."

#: ../../source/user_guide/dsp_effects.rst:257
#: 4e2bdc592796441fbaa2fd0dd137d94e
msgid "多个效果顺序是否和预期一致。"
msgstr "Whether the order of multiple effects matches your expectation."
