#: 9b5828400aa747318b3ea86e198a8af4
msgid "UI 声、按钮声"
msgstr "UI sounds and button sounds"

#: ../../source/user_guide/audio_resources.rst:26
#: ../../source/user_guide/audio_resources.rst:29
