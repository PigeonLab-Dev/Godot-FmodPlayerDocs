msgstr "Recommended mode"

#: ../../source/user_guide/audio_resources.rst:18
#: 99292f692e0142fca121fd197b117d9a
msgid "原因"
msgstr "Reason"

#: ../../source/user_guide/audio_resources.rst:19
#: e581cfba010b4ebca388ac39714291e4
msgid "背景音乐"
msgstr "Background music"

#: ../../source/user_guide/audio_resources.rst:20
#: ../../source/user_guide/audio_resources.rst:23
#: ../../source/user_guide/audio_resources.rst:50
#: 56933bdef19b4432b934f4c96e056b99
