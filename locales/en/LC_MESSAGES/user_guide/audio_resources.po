#: f4f5147aa6e64041944321ef3892a721
msgid "var flags := FmodAudioStream.MODE_STREAM | FmodAudioStream.MODE_LOOP"
msgstr "var flags := FmodAudioStream.MODE_STREAM | FmodAudioStream.MODE_LOOP"

#: ../../source/user_guide/audio_resources.rst:66
#: 108cc07d1c054e1f8da688c7ca66b186
msgid "从文件加载"
msgstr "Load from a File"

#: ../../source/user_guide/audio_resources.rst:68
#: 1cd3fbaa91284dd8bb11de075dd15695
msgid "推荐优先使用 ``res://`` 路径，这样导出项目时更容易保持一致。"
msgstr "Prefer ``res://`` paths so exported projects stay consistent."

#: ../../source/user_guide/audio_resources.rst:70
#: 30c6867ef99e4a7db16afb43424f3092
msgid ""
"var music := FmodAudioStream.load_from_file(\n"
"    \"res://music/bgm.ogg\",\n"
"    FmodAudioStream.MODE_STREAM | FmodAudioStream.MODE_LOOP\n"
")\n"
"\n"
"var hit := FmodAudioStream.load_from_file(\n"
"    \"res://sfx/hit.wav\",\n"
"    FmodAudioStream.MODE_SAMPLE\n"
")"
msgstr ""
"var music := FmodAudioStream.load_from_file(\n"
"    \"res://music/bgm.ogg\",\n"
"    FmodAudioStream.MODE_STREAM | FmodAudioStream.MODE_LOOP\n"
")\n"
"\n"
"var hit := FmodAudioStream.load_from_file(\n"
"    \"res://sfx/hit.wav\",\n"
"    FmodAudioStream.MODE_SAMPLE\n"
")"

#: ../../source/user_guide/audio_resources.rst:82
#: fdaca9316a1e4acabbb52fd595866206
msgid "加载后可以直接交给播放器："
msgstr "After loading, you can assign it directly to a player:"

#: ../../source/user_guide/audio_resources.rst:84
#: 9372696c3c4a4ca48623764b0745674a
msgid ""
"@onready var music_player := $FmodAudioStreamPlayer\n"
"\n"
"func _ready():\n"
"    music_player.stream = music\n"
"    music_player.bus = \"Music\"\n"
"    music_player.play()"
msgstr ""
"@onready var music_player := $FmodAudioStreamPlayer\n"
"\n"
"func _ready():\n"
"    music_player.stream = music\n"
"    music_player.bus = \"Music\"\n"
"    music_player.play()"

#: ../../source/user_guide/audio_resources.rst:94
#: 25e174a8ef384624a09286611210b532
msgid "从内存加载"
msgstr "Load from Memory"

#: ../../source/user_guide/audio_resources.rst:96
#: 66110d96b6044cfb944f32f5abc27539
msgid "如果音频来自加密包、网络、存档或你自己的加载流程，可以把二进制数据放进 ``audio_data``。"
msgstr ""
"If audio comes from an encrypted package, the network, a save file, or your own loading flow, put the binary data into ``audio_data``."

#: ../../source/user_guide/audio_resources.rst:98
#: f4fb89b0f9044381a224d34ffaab0f3f
msgid ""
"func load_from_bytes(data: PackedByteArray) -> FmodAudioStream:\n"
"    var stream := FmodAudioStream.new()\n"
"    stream.audio_data = data\n"
"    stream.mode_flags = FmodAudioStream.MODE_SAMPLE\n"
"    return stream"
msgstr ""
"func load_from_bytes(data: PackedByteArray) -> FmodAudioStream:\n"
"    var stream := FmodAudioStream.new()\n"
"    stream.audio_data = data\n"
"    stream.mode_flags = FmodAudioStream.MODE_SAMPLE\n"
"    return stream"

#: ../../source/user_guide/audio_resources.rst:106
#: a21ab44db975462599eb4b45a7f1e119
msgid "这种方式要注意：播放期间资源对象必须还活着。不要在声音还没播放完时把保存数据的对象释放掉。"
msgstr ""
"When using this method, keep the resource object alive while the sound is playing. Do not free the object that stores the data before playback finishes."

#: ../../source/user_guide/audio_resources.rst:109
#: 1dd0d79097784b2582279afe328390f8
msgid "预加载常用音效"
msgstr "Preload Common Sound Effects"

#: ../../source/user_guide/audio_resources.rst:111
#: c58a0d4dc1e345469c9a6c09ff0ad702
msgid "短音效经常会反复播放。可以在场景开始时先加载好，之后直接复用。"
msgstr "Short sound effects are often played repeatedly. You can load them when the scene starts and reuse them later."

#: ../../source/user_guide/audio_resources.rst:113
#: b96706580fc446e39c69c94253cc099d
msgid ""
"extends Node\n"
"\n"
"var sfx := {}\n"
"\n"
"func _ready():\n"
"    sfx[\"hit\"] = FmodAudioStream.load_from_file(\n"
"        \"res://sfx/hit.wav\",\n"
"        FmodAudioStream.MODE_SAMPLE\n"
"    )\n"
"    sfx[\"pickup\"] = FmodAudioStream.load_from_file(\n"
"        \"res://sfx/pickup.wav\",\n"
"        FmodAudioStream.MODE_SAMPLE\n"
"    )\n"
"\n"
"func play_sfx(name: String):\n"
"    if not sfx.has(name):\n"
"        push_error(\"SFX not found: \" + name)\n"
"        return\n"
"\n"
"    var player := FmodAudioStreamPlayer.new()\n"
"    add_child(player)\n"
"    player.stream = sfx[name]\n"
"    player.bus = \"SFX\"\n"
"    player.play()\n"
"\n"
"    await get_tree().create_timer(3.0).timeout\n"
"    player.queue_free()"
msgstr ""
"extends Node\n"
"\n"
"var sfx := {}\n"
"\n"
"func _ready():\n"
"    sfx[\"hit\"] = FmodAudioStream.load_from_file(\n"
"        \"res://sfx/hit.wav\",\n"
"        FmodAudioStream.MODE_SAMPLE\n"
"    )\n"
"    sfx[\"pickup\"] = FmodAudioStream.load_from_file(\n"
"        \"res://sfx/pickup.wav\",\n"
"        FmodAudioStream.MODE_SAMPLE\n"
"    )\n"
"\n"
"func play_sfx(name: String):\n"
"    if not sfx.has(name):\n"
"        push_error(\"SFX not found: \" + name)\n"
"        return\n"
"\n"
"    var player := FmodAudioStreamPlayer.new()\n"
"    add_child(player)\n"
"    player.stream = sfx[name]\n"
"    player.bus = \"SFX\"\n"
"    player.play()\n"
"\n"
"    await get_tree().create_timer(3.0).timeout\n"
"    player.queue_free()"

#: ../../source/user_guide/audio_resources.rst:143
#: 1e98ed338ed44881b4996d671e1b83b7
msgid "如果你的项目会大量重叠播放短音效，可以进一步做播放器对象池。入门阶段先用上面的方式更容易理解。"
msgstr ""
"If your project plays many overlapping short sound effects, you can go further and use a player object pool. For beginners, the approach above is easier to understand."

#: ../../source/user_guide/audio_resources.rst:146
#: 0b5d55a1bdcf49e8b57befcec0a3e8f0
msgid "背景音乐播放列表"
msgstr "Background Music Playlist"

#: ../../source/user_guide/audio_resources.rst:148
#: 6ca92ce57e1e45569aad6dea020b50fa
msgid "音乐通常用 ``MODE_STREAM``，需要循环时再加 ``MODE_LOOP``。"
msgstr "Music usually uses ``MODE_STREAM``. Add ``MODE_LOOP`` when it needs to loop."

#: ../../source/user_guide/audio_resources.rst:150
#: 1cf3a019439547dda1e25101e76b3361
msgid ""
"extends Node\n"
"\n"
"@onready var player := $FmodAudioStreamPlayer\n"
"var tracks: Array[FmodAudioStream] = []\n"
"var current_index := 0\n"
"\n"
"func _ready():\n"
"    tracks.append(FmodAudioStream.load_from_file(\n"
"        \"res://music/track_0.ogg\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    ))\n"
"    tracks.append(FmodAudioStream.load_from_file(\n"
"        \"res://music/track_1.ogg\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    ))\n"
"\n"
"    play_track(0)\n"
"\n"
"func play_track(index: int):\n"
"    current_index = index\n"
"    player.stream = tracks[index]\n"
"    player.bus = \"Music\"\n"
"    player.play()"
msgstr ""
"extends Node\n"
"\n"
"@onready var player := $FmodAudioStreamPlayer\n"
"var tracks: Array[FmodAudioStream] = []\n"
"var current_index := 0\n"
"\n"
"func _ready():\n"
"    tracks.append(FmodAudioStream.load_from_file(\n"
"        \"res://music/track_0.ogg\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    ))\n"
"    tracks.append(FmodAudioStream.load_from_file(\n"
"        \"res://music/track_1.ogg\",\n"
"        FmodAudioStream.MODE_STREAM\n"
"    ))\n"
"\n"
"    play_track(0)\n"
"\n"
"func play_track(index: int):\n"
"    current_index = index\n"
"    player.stream = tracks[index]\n"
"    player.bus = \"Music\"\n"
"    player.play()"

#: ../../source/user_guide/audio_resources.rst:177
#: 87148c9ec29546548f80980428843dd8
msgid "查询音频信息"
msgstr "Query Audio Information"

#: ../../source/user_guide/audio_resources.rst:179
#: fefab0713971424faf55e548039c498b
msgid "``FmodAudioStream`` 可以查询长度，也可以取得底层 :ref:`Sound<glossary-sound>`。"
msgstr "``FmodAudioStream`` can query length and access the underlying :ref:`Sound<glossary-sound>`."

#: ../../source/user_guide/audio_resources.rst:181
#: 27ac5c14b56d4ade9b26295b051e48eb
msgid ""
"func print_stream_info(stream: FmodAudioStream):\n"
"    print(\"loaded: \", stream.is_data_loaded())\n"
"    print(\"length: \", stream.get_length())\n"
"\n"
"    var sound := stream.get_sound()\n"
"    if sound:\n"
"        print(\"sound length: \", sound.get_length())"
msgstr ""
"func print_stream_info(stream: FmodAudioStream):\n"
"    print(\"loaded: \", stream.is_data_loaded())\n"
"    print(\"length: \", stream.get_length())\n"
"\n"
"    var sound := stream.get_sound()\n"
"    if sound:\n"
"        print(\"sound length: \", sound.get_length())"

#: ../../source/user_guide/audio_resources.rst:191
#: 58ca437a278e40968e3814b916959255
msgid "普通播放通常不需要直接操作 ``FmodSound``。只有在你需要更底层的信息、回调或特殊播放控制时，才去拿它。"
msgstr ""
"Normal playback usually does not require direct access to ``FmodSound``. Get it only when you need lower-level information, callbacks, or special playback control."

#: ../../source/user_guide/audio_resources.rst:194
#: 9237d97a25bc49ad891241848ddf61e1
msgid "支持格式"
msgstr "Supported Formats"

#: ../../source/user_guide/audio_resources.rst:196
#: d19f51efaab74759afc9b8cc444ff4d0
msgid "常见格式包括 ``.wav``、``.ogg``、``.mp3``、``.flac``、``.aiff``，以及部分模块音乐格式如 ``.mod``、``.xm``、``.s3m``、``.it``。"
msgstr ""
"Common formats include ``.wav``, ``.ogg``, ``.mp3``, ``.flac``, ``.aiff``, and some module music formats such as ``.mod``, ``.xm``, ``.s3m``, and ``.it``."

#: ../../source/user_guide/audio_resources.rst:198
#: 998a37b56a224e1da677661bd7ebe91e
msgid "实用建议："
msgstr "Practical suggestions:"

#: ../../source/user_guide/audio_resources.rst:200
#: bb3f40d2772144eda4124fd45826620b
msgid "音乐优先考虑 ``ogg`` 或 ``mp3``。"
msgstr "Prefer ``ogg`` or ``mp3`` for music."

#: ../../source/user_guide/audio_resources.rst:201
#: a2a32fece2a84ad385d42ee05fa4b626
msgid "短音效优先考虑 ``wav``。"
msgstr "Prefer ``wav`` for short sound effects."

#: ../../source/user_guide/audio_resources.rst:202
#: ad83bd1396cf415bb33068c13a131c49
msgid "需要无缝循环时，优先测试 ``ogg`` 或 ``wav`` 的循环点表现。"
msgstr "When seamless looping matters, test loop points with ``ogg`` or ``wav`` first."

#: ../../source/user_guide/audio_resources.rst:203
#: 3f77bc9a428d419babca0181119bf341
msgid "特殊格式在导出前一定要在目标平台测试。"
msgstr "Always test special formats on the target platform before export."

#: ../../source/user_guide/audio_resources.rst:206
#: 2e8f151bc4f94ff99010a497fa105c56
msgid "常见问题"
msgstr "Common Issues"

#: ../../source/user_guide/audio_resources.rst:209
#: 1e108566aa77416d98d70a6e90b85ca0
msgid "音效第一次播放有延迟"
msgstr "The first playback of a sound effect has latency"

#: ../../source/user_guide/audio_resources.rst:211
#: 2ee866afbc4940dd8fce1acbef9cb0aa
msgid "把短音效用 ``MODE_SAMPLE`` 加载，并在进入场景前预加载。"
msgstr "Load short sound effects with ``MODE_SAMPLE`` and preload them before entering the scene."

#: ../../source/user_guide/audio_resources.rst:214
#: 618506933a8c4df2b5227a9e5720ffda
msgid "音乐占用内存太高"
msgstr "Music uses too much memory"

#: ../../source/user_guide/audio_resources.rst:216
#: a640592fae0646fcb52553a1bb83409a
msgid "检查是否把音乐用了 ``MODE_SAMPLE``。长音乐一般应该使用 ``MODE_STREAM``。"
msgstr "Check whether the music was loaded with ``MODE_SAMPLE``. Long music should usually use ``MODE_STREAM``."

#: ../../source/user_guide/audio_resources.rst:219
#: d8305f400a244f4aa25ce9db285414af
msgid "循环不生效"
msgstr "Looping does not work"

#: ../../source/user_guide/audio_resources.rst:221
#: 2b631a70ab4948f9844643751f5214bc
msgid "确认创建模式里包含 ``MODE_LOOP``："
msgstr "Make sure the creation mode includes ``MODE_LOOP``:"

#: ../../source/user_guide/audio_resources.rst:223
#: a84f2b6d0bc7492781d4a7b71c95fb9f
msgid "stream.mode_flags = FmodAudioStream.MODE_STREAM | FmodAudioStream.MODE_LOOP"
msgstr "stream.mode_flags = FmodAudioStream.MODE_STREAM | FmodAudioStream.MODE_LOOP"

